# Server Environment Variables
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/onlyhair
REDIS_URL=redis://localhost:6379

# Auth (RSA Keys - Use base64 encoded or path to keys in production)
JWT_PRIVATE_KEY="your_private_key_here"
JWT_PUBLIC_KEY="your_public_key_here"

# AWS
AWS_ACCESS_KEY="your_aws_access_key"
AWS_SECRET_KEY="your_aws_secret_key"
AWS_REGION=ap-south-1
AWS_S3_BUCKET=onlyhair-assets

# Payments
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_SECRET="your_razorpay_secret"

# Frontend URL
CLIENT_URL=http://localhost:3000
